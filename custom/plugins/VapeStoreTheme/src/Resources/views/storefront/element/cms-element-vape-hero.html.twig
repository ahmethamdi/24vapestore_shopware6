{#
    Hero slider — storefront çıktısı.

    ⚠️ Dosya adı `cms-element-vape-hero.html.twig` OLMAK ZORUNDA.
       Block şablonu `sw_include ... ~ element.type ~ ...` ile çağırır ve
       `ignore missing` yüzünden yanlış isim SESSİZCE boş render eder.

    Slide verisi PHP resolver'dan `element.data.slides` olarak gelir; her eleman
    çözümlenmiş `media` ve `products` entity'lerini içerir. Metinler config'te
    dizi içinde tutulduğu için `element.translated.config` çeviri katmanı bu
    alanlara uygulanmaz — çok dilli mağazada slide metinleri için ileride
    ayrı bir çeviri stratejisi gerekir (şimdilik tek dil).
#}
{% block element_vape_hero %}
    {% set layout = element.config %}
    {% set slides = element.data.slides|default([]) %}

    {% set minHeight = layout.minHeight.value|default(520) %}
    {% set showArrows = layout.showArrows.value|default(true) and slides|length > 1 %}
    {% set showDots = layout.showDots.value|default(true) and slides|length > 1 %}
    {% set showProducts = layout.showProducts.value|default(true) %}
    {% set autoplay = layout.autoplay.value|default(false) and slides|length > 1 %}
    {% set autoplaySpeed = layout.autoplaySpeed.value|default(6000) %}

    {% if slides|length > 0 %}
        <div class="cms-element-{{ element.type }} vape-hero"
             style="--vape-hero-min-height: {{ minHeight }}px;"
             data-vape-hero-slider="true"
             data-vape-hero-slider-options='{{ {
                 autoplay: autoplay,
                 speed: autoplaySpeed
             }|json_encode }}'>

            {% block element_vape_hero_track %}
                <div class="vape-hero__track" data-vape-hero-track>

                    {% for slide in slides %}
                        {% block element_vape_hero_slide %}
                            <div class="vape-hero__slide is--tone-{{ slide.textColor }}"
                                 data-vape-hero-slide
                                 aria-hidden="{{ loop.first ? 'false' : 'true' }}">

                                {# ---------- sol renkli panel ---------- #}
                                <div class="vape-hero__panel" style="background-color: {{ slide.bgColor }};">
                                    <div class="vape-hero__panel-inner">

                                        {% if slide.eyebrow %}
                                            <span class="vape-hero__eyebrow">{{ slide.eyebrow }}</span>
                                        {% endif %}

                                        {% if slide.kicker %}
                                            <span class="vape-hero__kicker">{{ slide.kicker }}</span>
                                        {% endif %}

                                        {% if slide.headline %}
                                            <h2 class="vape-hero__headline">{{ slide.headline }}</h2>
                                        {% endif %}

                                        {% if showDots %}
                                            <div class="vape-hero__dots" data-vape-hero-dots role="tablist"
                                                 aria-label="{{ 'vapeHero.slideNavigation'|trans|sw_sanitize }}">
                                                {% for i in 0..(slides|length - 1) %}
                                                    <button type="button"
                                                            class="vape-hero__dot{{ loop.first ? ' is--active' : '' }}"
                                                            data-vape-hero-dot="{{ i }}"
                                                            role="tab"
                                                            aria-selected="{{ loop.first ? 'true' : 'false' }}"
                                                            aria-label="{{ 'vapeHero.goToSlide'|trans({'%number%': i + 1})|sw_sanitize }}"></button>
                                                {% endfor %}
                                            </div>
                                        {% endif %}

                                        {% if slide.ctaText and slide.ctaUrl %}
                                            <a href="{{ slide.ctaUrl }}"
                                               class="btn btn-primary vape-hero__cta"
                                               {% if slide.newTab %}target="_blank" rel="noopener noreferrer"{% endif %}>
                                                {{ slide.ctaText }}
                                            </a>
                                        {% endif %}

                                        {% if showProducts and slide.products|length > 0 %}
                                            <div class="vape-hero__products">
                                                {% for product in slide.products %}
                                                    <a href="{{ seoUrl('frontend.detail.page', { productId: product.id }) }}"
                                                       class="vape-hero__product"
                                                       title="{{ product.translated.name }}">
                                                        {% if product.cover.media %}
                                                            {% sw_thumbnails 'vape-hero-product-thumbnails' with {
                                                                media: product.cover.media,
                                                                sizes: { default: '120px' },
                                                                attributes: {
                                                                    class: 'vape-hero__product-image',
                                                                    alt: product.translated.name,
                                                                    loading: 'lazy'
                                                                }
                                                            } %}
                                                        {% endif %}
                                                    </a>
                                                {% endfor %}
                                            </div>
                                        {% endif %}

                                    </div>
                                </div>

                                {# ---------- sağ görsel ----------
                                   Görsel seçilmemişse Shopware'in hazır CMS görseli
                                   gösterilir — böylece slide asla boş gri kutu olmaz
                                   ve yönetici düzeni gerçekçi görür. #}
                                <div class="vape-hero__media">
                                    {% if slide.media %}
                                        {% sw_thumbnails 'vape-hero-image-thumbnails' with {
                                            media: slide.media,
                                            sizes: {
                                                xs: '576px',
                                                sm: '767px',
                                                md: '991px',
                                                lg: '1199px',
                                                xl: '1920px'
                                            },
                                            attributes: {
                                                class: 'vape-hero__image',
                                                alt: (slide.media.translated.alt ?: slide.headline),
                                                loading: (loop.first ? 'eager' : 'lazy')
                                            }
                                        } %}
                                    {% else %}
                                        <img src="{{ asset('assets/default/cms/preview_mountain_large.jpg', 'asset') }}"
                                             class="vape-hero__image vape-hero__image--placeholder"
                                             alt=""
                                             loading="{{ loop.first ? 'eager' : 'lazy' }}" />
                                    {% endif %}
                                </div>

                            </div>
                        {% endblock %}
                    {% endfor %}

                </div>
            {% endblock %}

            {% block element_vape_hero_arrows %}
                {% if showArrows %}
                    <div class="vape-hero__arrows">
                        <button type="button"
                                class="vape-hero__arrow vape-hero__arrow--prev"
                                data-vape-hero-prev
                                aria-label="{{ 'vapeHero.previousSlide'|trans|sw_sanitize }}">
                            {% sw_icon 'arrow-medium-left' %}
                        </button>
                        <button type="button"
                                class="vape-hero__arrow vape-hero__arrow--next"
                                data-vape-hero-next
                                aria-label="{{ 'vapeHero.nextSlide'|trans|sw_sanitize }}">
                            {% sw_icon 'arrow-medium-right' %}
                        </button>
                    </div>
                {% endif %}
            {% endblock %}

        </div>
    {% endif %}
{% endblock %}
